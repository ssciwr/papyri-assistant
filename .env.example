LLM_API_KEY=your-provider-key
LLM_API_URL=https://your-provider.example/v1
LLM_MODEL=your-chat-model
BACKEND_PORT=3001
VITE_WARNING_BANNER_TEXT=
POSTGRES_DATA_DIR=./data/postgres

# Development compose defaults to CORS_ORIGIN=http://localhost:5173 and
# VITE_API_URL=http://localhost:3001 when these are unset.
# Production compose defaults to PROD_VITE_API_URL=/api so nginx can proxy requests.
# CORS_ORIGIN=https://your-domain.example
# PROD_VITE_API_URL=/api

FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443
TLS_CERTIFICATE_PATH=./certs/tls.pem
TLS_PRIVATE_KEY_PATH=./certs/tls.key
